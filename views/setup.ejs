<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project CLI — Initial Setup</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f9fafb; color: #111827; }
    .step { display: none; }
    .step.active { display: block; animation: slideIn 0.4s ease-out; }
    @keyframes slideIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    input { caret-color: black; }
  </style>
</head>
<body class="min-h-screen flex flex-col justify-center items-center p-6 bg-gray-50">

  <div class="w-full max-w-xl">
    
    <!-- Progress Indicator -->
    <div class="flex items-center justify-between mb-10 px-4 relative">
      <div class="absolute top-1/2 left-4 right-4 h-0.5 bg-gray-200 -z-10 -translate-y-1/2 rounded-full"></div>
      <div class="absolute top-1/2 left-4 h-0.5 bg-black -z-10 -translate-y-1/2 rounded-full transition-all duration-300" id="progressLine" style="width: 0%"></div>
      
      <div class="flex flex-col items-center gap-2">
        <div id="dot-1" class="w-8 h-8 rounded-full bg-black text-white flex items-center justify-center font-semibold text-sm shadow-md transition-colors">1</div>
        <span class="text-[10px] font-bold uppercase tracking-widest text-black">Welcome</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div id="dot-2" class="w-8 h-8 rounded-full bg-white border-2 border-gray-300 text-gray-400 flex items-center justify-center font-semibold text-sm transition-colors">2</div>
        <span id="text-2" class="text-[10px] font-bold uppercase tracking-widest text-gray-400 transition-colors">Workspace</span>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div id="dot-3" class="w-8 h-8 rounded-full bg-white border-2 border-gray-300 text-gray-400 flex items-center justify-center font-semibold text-sm transition-colors">3</div>
        <span id="text-3" class="text-[10px] font-bold uppercase tracking-widest text-gray-400 transition-colors">Security</span>
      </div>
    </div>

    <div class="bg-white rounded-[2rem] border border-gray-200 shadow-sm p-10 relative overflow-hidden">
      <!-- Decorator line -->
      <div class="absolute top-0 left-0 w-full h-1 bg-black"></div>

      <!-- Step 1: Welcome -->
      <div id="step-1" class="step active">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-6">
          <span class="text-3xl">🚀</span>
        </div>
        <h1 class="text-2xl font-bold mb-3 text-gray-900">Welcome to Project CLI</h1>
        <p class="text-gray-500 text-sm leading-relaxed mb-8">
          A powerful local dashboard for managing your Node, React, Python, and Ruby microservices in the background. Setup takes only 30 seconds.
        </p>
        <button onclick="nextStep(2)" class="w-full bg-black text-white font-bold py-4 rounded-xl hover:bg-gray-800 transition shadow-md">
          Start Local Setup &rarr;
        </button>
      </div>

      <!-- Step 2: Org & CLI Name -->
      <div id="step-2" class="step">
        <h2 class="text-xl font-bold mb-2">Workspace Config</h2>
        <p class="text-gray-500 text-xs mb-8">Customize your command line execution and organization name.</p>
        
        <div class="space-y-5">
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">Organization Name</label>
            <input id="orgName" type="text" placeholder="e.g. your-company" required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-300 rounded-xl focus:outline-none focus:border-black focus:ring-1 focus:ring-black transition font-medium text-sm">
            <p class="text-[10px] text-gray-400 mt-2 font-medium">Used for package branding: <code class="bg-gray-100 px-1 py-0.5 rounded text-black font-bold">@<span id="orgPreview">your-company</span>/...</code></p>
          </div>
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">Global CLI Command</label>
            <input id="cliName" type="text" placeholder="e.g. dev-cli" required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-300 rounded-xl focus:outline-none focus:border-black focus:ring-1 focus:ring-black transition font-medium text-sm">
            <p class="text-[10px] text-gray-400 mt-2 font-medium">Type this in terminal to run the CLI version.</p>
          </div>
        </div>

        <div class="flex gap-4 mt-10">
          <button onclick="nextStep(1)" class="w-1/3 bg-gray-100 text-gray-600 font-bold py-4 rounded-xl hover:bg-gray-200 transition border border-gray-200">Back</button>
          <button onclick="nextStep(3)" class="w-2/3 bg-black text-white font-bold py-4 rounded-xl hover:bg-gray-800 transition shadow-md">Continue</button>
        </div>
      </div>

      <!-- Step 3: Admin Account -->
      <div id="step-3" class="step">
        <h2 class="text-xl font-bold mb-2">Security</h2>
        <p class="text-gray-500 text-xs mb-8">Create your local admin account. This protects your API endpoints.</p>
        
        <div class="space-y-4">
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">Username</label>
            <input id="username" type="text" placeholder="admin" required value="admin"
              class="w-full px-4 py-3 bg-gray-50 border border-gray-300 rounded-xl focus:outline-none focus:border-black focus:ring-1 focus:ring-black transition font-medium text-sm">
          </div>
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">Password</label>
            <input id="password" type="password" placeholder="Min 8 chars" required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-300 rounded-xl focus:outline-none focus:border-black focus:ring-1 focus:ring-black transition font-medium text-sm">
          </div>
          <div>
            <label class="block text-[11px] font-bold uppercase tracking-wider text-gray-500 mb-2">Confirm Password</label>
            <input id="confirmPassword" type="password" placeholder="Confirm" required
              class="w-full px-4 py-3 bg-gray-50 border border-gray-300 rounded-xl focus:outline-none focus:border-black focus:ring-1 focus:ring-black transition font-medium text-sm">
          </div>
          <div id="errMsg" class="hidden text-sm font-bold text-red-500 mt-2"></div>
        </div>

        <div class="flex items-center gap-4 mt-8">
          <button onclick="nextStep(2)" id="backBtn" class="w-1/3 bg-gray-100 text-gray-600 font-bold py-4 rounded-xl hover:bg-gray-200 transition border border-gray-200">Back</button>
          <button onclick="finishSetup()" id="finishBtn" class="w-2/3 bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition shadow-md flex justify-center items-center gap-2">
            <span>Complete Setup</span>
            <span id="spin" class="hidden"><svg class="animate-spin h-4 w-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg></span>
          </button>
        </div>
      </div>

    </div>
  </div>

  <script>
    document.getElementById('orgName').addEventListener('input', e => {
      document.getElementById('orgPreview').textContent = e.target.value.trim() || 'your-company';
    });

    function updateProgress(step) {
      document.querySelectorAll('.step').forEach(el => el.classList.remove('active'));
      document.getElementById(`step-${step}`).classList.add('active');
      
      const lineMap = { 1: '0%', 2: '50%', 3: '100%' };
      document.getElementById('progressLine').style.width = lineMap[step];

      for (let i = 1; i <= 3; i++) {
        const dot = document.getElementById(`dot-${i}`);
        const txt = document.getElementById(`text-${i}`);
        if (i <= step) {
          dot.className = "w-8 h-8 rounded-full bg-black text-white flex items-center justify-center font-bold text-sm shadow-md transition-all";
          if(txt) txt.className = "text-[10px] font-bold uppercase tracking-widest text-black transition-all";
        } else {
          dot.className = "w-8 h-8 rounded-full bg-white border-2 border-gray-300 text-gray-400 flex items-center justify-center font-bold text-sm transition-all";
          if(txt) txt.className = "text-[10px] font-bold uppercase tracking-widest text-gray-400 transition-all";
        }
      }
    }

    function nextStep(step) { updateProgress(step); }

    async function finishSetup() {
      const orgName = document.getElementById('orgName').value.trim();
      const cliName = document.getElementById('cliName').value.trim();
      const username = document.getElementById('username').value.trim();
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      const errEl = document.getElementById('errMsg');
      
      errEl.classList.add('hidden');
      
      if (!orgName || !cliName) { nextStep(2); return; }
      if (!username || password.length < 8) {
        errEl.textContent = 'Username is required. Password must be at least 8 chars.';
        errEl.classList.remove('hidden'); return;
      }
      if (password !== confirmPassword) {
        errEl.textContent = 'Passwords do not match!';
        errEl.classList.remove('hidden'); return;
      }

      const btn = document.getElementById('finishBtn');
      const backBtn = document.getElementById('backBtn');
      const spin = document.getElementById('spin');
      btn.disabled = true; backBtn.disabled = true;
      spin.classList.remove('hidden');

      try {
        const r = await fetch('/api/setup-init', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ orgName, cliName, username, password })
        });
        const data = await r.json();
        
        if (r.ok && data.success) {
          // Immediately login
          const lr = await fetch('/api/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password })
          });
          const ldata = await lr.json();
          if (lr.ok && ldata.token) {
            localStorage.setItem('da_token', ldata.token);
            window.location.href = '/dashboard';
          } else {
            window.location.href = '/';
          }
        } else {
          errEl.textContent = data.error || 'Setup failed.';
          errEl.classList.remove('hidden');
          btn.disabled = false; backBtn.disabled = false; spin.classList.add('hidden');
        }
      } catch (err) {
        errEl.textContent = 'Network error during setup.';
        errEl.classList.remove('hidden');
        btn.disabled = false; backBtn.disabled = false; spin.classList.add('hidden');
      }
    }
  </script>
</body>
</html>
