  `;

  // Update APM Charts & Health Score
  updateChartLive(p);
  const healthScore = Math.max(0, 100 - (p.cpu || 0)/2 - (p.restarts || 0)*2);
  let hText = "Hệ thống hoạt động hoàn hảo, trơn tru.";
  if (healthScore < 80) hText = "Có dấu hiệu suy giảm hiệu năng (CPU cao hoặc restart nhiều).";
  if (healthScore < 50) hText = "Cảnh báo: Ứng dụng không ổn định, cần kiểm tra ngay lập tức!";
