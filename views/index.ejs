<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Project CLI</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --red: #dc2626;
      --red-dim: #991b1b;
      --red-bg: #fef2f2;
      --red-border: #fca5a5;
      --black: #0a0a0a;
      --gray-900: #111111;
      --gray-800: #1f1f1f;
      --gray-700: #2e2e2e;
      --gray-600: #444444;
      --gray-500: #666666;
      --gray-400: #888888;
      --gray-300: #b0b0b0;
      --gray-200: #d4d4d4;
      --gray-150: #e5e5e5;
      --gray-100: #f0f0f0;
      --gray-50: #f8f8f8;
      --white: #ffffff;
      --green: #16a34a;
      --yellow: #ca8a04;
      --sidebar-bg: #ffffff;
      --sidebar-hover: #f5f5f5;
      --sidebar-active: #fafafa;
      --sidebar-border: #e8e8e8;
    }
    html, body { height: 100%; overflow: hidden; }
    body { font-family: 'Inter', sans-serif; background: var(--gray-50); color: var(--black); font-size: 13px; }
    .mono { font-family: 'JetBrains Mono', monospace; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--gray-300); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--gray-400); }

    /* Layout */
    .layout { display: flex; height: 100vh; overflow: hidden; flex-direction: column; }
    .body-row { display: flex; flex: 1; overflow: hidden; }

    /* Top bar */
    .topbar { height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 16px; background: var(--white); border-bottom: 1px solid var(--gray-150); flex-shrink: 0; z-index: 10; }
    .topbar-left { display: flex; align-items: center; gap: 12px; }
    .topbar-logo { width: 26px; height: 26px; background: var(--black); border-radius: 6px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .topbar-logo svg { width: 14px; height: 14px; color: white; }
    .topbar-title { font-weight: 700; font-size: 13px; color: var(--black); }
    .topbar-pkg { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gray-400); background: var(--gray-100); padding: 2px 8px; border-radius: 4px; border: 1px solid var(--gray-150); }
    .topbar-right { display: flex; align-items: center; gap: 8px; }
    .badge { display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 500; padding: 3px 9px; border-radius: 20px; border: 1px solid var(--gray-200); background: var(--gray-50); color: var(--gray-500); }
    .badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gray-400); }
    .badge.ok .dot { background: var(--green); }
    .badge.err .dot { background: var(--red); }
    .sysinfo { font-size: 11px; color: var(--gray-400); font-family: 'JetBrains Mono', monospace; display:flex; align-items:center; gap:4px; }
    .sysinfo:hover { color: var(--gray-600); }
    .btn-ghost { font-size: 12px; color: var(--gray-500); padding: 4px 10px; border-radius: 6px; cursor: pointer; background: none; border: none; transition: background .15s, color .15s; }
    .btn-ghost:hover { background: var(--gray-100); color: var(--black); }

    /* Sidebar */
    .sidebar { width: 256px; flex-shrink: 0; display: flex; flex-direction: column; background: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); overflow: hidden; }
    .sidebar-head { padding: 12px 12px 8px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--sidebar-border); flex-shrink: 0; }
    .sidebar-head-tabs { display: flex; gap: 0; }
    .stab { font-size: 11px; font-weight: 500; padding: 4px 10px; border-radius: 5px; cursor: pointer; background: none; border: none; color: var(--gray-400); transition: all .15s; }
    .stab.active { background: var(--black); color: var(--white); }
    .stab:hover:not(.active) { color: var(--gray-600); background: var(--gray-100); }
    .sidebar-body { flex: 1; overflow-y: auto; }
    .spanel { display: none; flex-direction: column; }
    .spanel.active { display: flex; }

    /* Add project btn wrapper */
    .add-btn-wrap { position: sticky; top: 0; z-index: 20; background: var(--sidebar-bg); padding-bottom: 4px; border-bottom: 1px solid var(--sidebar-border); margin-bottom: 8px; }

    .add-btn { margin: 10px; display: flex; align-items: center; justify-content: center; gap: 6px; font-size: 12px; font-weight: 500; color: var(--gray-400); background: var(--sidebar-bg); border: 1px dashed var(--gray-200); border-radius: 8px; padding: 9px 12px; cursor: pointer; transition: all .15s; width: calc(100% - 20px); }
    .add-btn:hover { border-color: var(--red); color: var(--red); background: rgba(220,38,38,.04); }

    /* Project item in sidebar */
    .proj-item { margin: 2px 8px; border-radius: 8px; padding: 10px 10px 8px; cursor: pointer; border: 1px solid gray; transition: all .15s; }
    .proj-item:hover { background: var(--gray-50); border-color: var(--gray-200); }
    .proj-item.selected { background: var(--white); border-color: var(--red) !important; box-shadow: 0 1px 6px rgba(220,38,38,.1); }
    .proj-item.selected .proj-name { color: var(--black); }
    .proj-row { display: flex; align-items: center; gap: 7px; margin-bottom: 4px; }
    .proj-name { font-size: 13px; font-weight: 600; color: var(--gray-700); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .proj-type { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; padding: 1px 5px; border-radius: 3px; flex-shrink: 0; }
    .type-Frontend { background: #eff6ff; color: #2563eb; }
    .type-Backend { background: #fff7ed; color: #c2410c; }
    .type-Fullstack { background: #faf5ff; color: #7e22ce; }
    .type-Service { background: #ecfeff; color: #0e7490; }
    .type-Other { background: var(--gray-100); color: var(--gray-500); }
    .proj-meta { font-size: 10px; color: var(--gray-400); font-family: 'JetBrains Mono', monospace; display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
    .proj-actions { display: flex; gap: 3px; }
    .pa-btn { flex: 1; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; padding: 4px 0; border-radius: 5px; border: 1px solid var(--gray-200); background: transparent; color: var(--gray-400); cursor: pointer; text-align: center; transition: all .12s; }
    .pa-btn:hover { background: var(--gray-100); color: var(--gray-700); border-color: var(--gray-300); }
    .pa-btn.start:hover { border-color: #bbf7d0; color: var(--green); background: #f0fdf4; }
    .pa-btn.restart:hover { border-color: #fde68a; color: #92400e; background: #fffbeb; }
    .pa-btn.stop:hover { border-color: var(--gray-300); color: var(--gray-600); background: var(--gray-50); }
    .pa-btn.del:hover { border-color: var(--red-border); color: var(--red); background: var(--red-bg); }

    /* Status dot */
    .dot-status { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .dot-online { background: #22c55e; box-shadow: 0 0 0 2px rgba(34,197,94,.3); }
    .dot-stopped { background: #9ca3af; }
    .dot-errored { background: #ef4444; box-shadow: 0 0 0 2px rgba(239,68,68,.3); }
    .dot-launching { background: #f59e0b; box-shadow: 0 0 0 2px rgba(245,158,11,.3); }

    /* Live log in sidebar */
    .log-panel { display: flex; flex-direction: column; flex: 1; padding: 8px; overflow: hidden; }
    .log-box { flex: 1; background: #1a1a1a; border-radius: 8px; overflow-y: auto; padding: 8px 10px; font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #9ca3af; white-space: pre-wrap; word-break: break-all; line-height: 1.6; border: 1px solid var(--gray-150); }
    .log-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
    .log-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--gray-400); }

    /* Main area */
    .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; background: var(--white); }
    .main-tabs { display: flex; align-items: center; padding: 0 20px; border-bottom: 1px solid var(--gray-150); background: var(--gray-50); flex-shrink: 0; gap: 0; }
    .mtab { font-size: 12px; font-weight: 500; padding: 11px 14px; cursor: pointer; background: none; border: none; border-bottom: 2px solid transparent; color: var(--gray-400); transition: all .15s; white-space: nowrap; }
    .mtab.active { color: var(--black); border-bottom-color: var(--red); font-weight: 600; }
    .mtab:hover:not(.active) { color: var(--gray-600); }
    .mtab.project-tab { color: var(--red); }
    .mtab.project-tab.active { color: var(--red); border-bottom-color: var(--red); }
    .tab-sep { width: 1px; height: 16px; background: var(--gray-200); margin: 0 4px; flex-shrink: 0; }
    .main-actions { margin-left: auto; display: flex; gap: 6px; align-items: center; padding-bottom: 2px; }
    .action-btn { font-size: 11px; font-weight: 600; padding: 5px 12px; border-radius: 6px; border: 1px solid var(--gray-200); background: var(--white); color: var(--gray-600); cursor: pointer; display: flex; align-items: center; gap: 5px; transition: all .12s; }
    .action-btn:hover { border-color: var(--gray-400); color: var(--black); }
    .action-btn.start-all:hover { border-color: var(--green); color: var(--green); background: #f0fdf4; }
    .action-btn.stop-all:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }

    /* Panels */
    .panel { display: none; flex: 1; overflow: hidden; }
    .panel.active { display: flex; flex-direction: column; }

    /* Terminal */
    .term-wrap { flex: 1; display: flex; flex-direction: column; margin: 12px; border-radius: 10px; overflow: hidden; background: #1a1a1a; box-shadow: 0 2px 12px rgba(0,0,0,.08); border: 1px solid var(--gray-200); }
    .term-out { flex: 1; overflow-y: auto; padding: 14px 16px; font-family: 'JetBrains Mono', monospace; font-size: 12.5px; color: #e4e4e7; white-space: pre-wrap; word-break: break-all; line-height: 1.65; }
    .term-in { display: flex; align-items: center; gap: 8px; padding: 10px 16px; border-top: 1px solid rgba(255,255,255,.06); background: #1a1a1a; }
    .term-prompt { color: #4ade80; font-family: 'JetBrains Mono', monospace; font-size: 13px; font-weight: 700; }
    .term-input { flex: 1; background: transparent; border: none; outline: none; color: var(--white); font-family: 'JetBrains Mono', monospace; font-size: 12.5px; caret-color: var(--red); }
    .term-btn { font-size: 11px; color: #4b5563; background: none; border: none; cursor: pointer; padding: 2px 6px; border-radius: 4px; transition: color .12s; }
    .term-btn:hover { color: #9ca3af; }

    /* Overview */
    .overview-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 14px; padding: 20px; overflow-y: auto; align-content: start; }
    .ov-card { background: var(--white); border: 1px solid var(--gray-150); border-radius: 12px; padding: 16px; transition: all .15s; }
    .ov-card:hover { border-color: var(--gray-300); box-shadow: 0 4px 16px rgba(0,0,0,.06); }
    .ov-card-head { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .ov-name { font-weight: 700; font-size: 14px; flex: 1; }
    .ov-status { font-size: 10px; font-weight: 700; text-transform: uppercase; color: var(--gray-400); }
    .ov-path { font-size: 11px; color: var(--gray-400); font-family: 'JetBrains Mono', monospace; background: var(--gray-50); padding: 5px 8px; border-radius: 5px; border: 1px solid var(--gray-100); margin-bottom: 12px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .ov-stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; margin-bottom: 12px; }
    .ov-stat { text-align: center; padding: 8px 4px; border: 1px solid var(--gray-100); border-radius: 7px; background: var(--gray-50); }
    .ov-stat-label { font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--gray-400); margin-bottom: 3px; }
    .ov-stat-val { font-size: 13px; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
    .ov-actions { display: flex; gap: 5px; }
    .ov-btn { flex: 1; font-size: 11px; font-weight: 600; padding: 6px 0; border-radius: 7px; border: 1px solid var(--gray-150); background: var(--gray-50); color: var(--gray-600); cursor: pointer; transition: all .12s; }
    .ov-btn:hover { background: var(--gray-100); border-color: var(--gray-300); }

    /* App settings */
    .settings-scroll { flex: 1; overflow-y: auto; padding: 24px 32px; background: #fafafa; }
    .settings-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 24px; align-items: stretch; }
    .card { background: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 28px; box-shadow: 0 8px 24px rgba(0,0,0,0.03); transition: transform 0.2s ease, box-shadow 0.2s ease; min-width: 0; display: flex; flex-direction: column; }
    .card:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,0.05); }
    .card-title { font-size: 16px; font-weight: 700; margin-bottom: 24px; display: flex; align-items: center; gap: 12px; color: var(--black); }
    .card-title i { color: #3b82f6; font-size: 18px; padding: 8px; background: #eff6ff; border-radius: 8px; display: inline-flex; align-items: center; justify-content: center; }
    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 20px; }
    .info-cell { background: #fafafa; border: 1px solid #eaeaea; border-radius: 10px; padding: 16px; transition: all .2s ease; position: relative; overflow: hidden; }
    .info-cell:hover { background: var(--white); border-color: #d4d4d4; box-shadow: 0 6px 16px rgba(0,0,0,.04); }
    .info-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: 6px; }
    .info-val { font-size: 14px; font-weight: 600; color: var(--black); }
    .divider { height: 1px; background: #eaeaea; margin: 24px 0; }
    .sec-title { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--gray-500); margin-bottom: 12px; }
    .input-row { display: flex; flex-direction: column; gap: 12px; }
    .full-span { grid-column: 1 / -1; }
    .inp { width: 100%; font-size: 14px; padding: 10px 14px; border: 1px solid #d4d4d4; border-radius: 9px; background: #fafafa; color: var(--black); outline: none; transition: all .2s; font-family: inherit; }
    .inp:hover { border-color: #a3a3a3; background: var(--white); box-shadow: 0 2px 8px rgba(0,0,0,0.02); }
    .inp:focus { border-color: #3b82f6; background: var(--white); box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }
    .inp.mono { font-family: 'JetBrains Mono', monospace; }
    .pwd-form-wrap { border-top: 1px solid #eaeaea; margin-top: 24px; padding-top: 24px; animation: fadeInDown 0.25s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
    @keyframes fadeInDown { from { opacity: 0; transform: translateY(-8px) } to { opacity: 1; transform: translateY(0) } }
    .token-row { display: flex; gap: 10px; align-items: flex-start; }
    .token-display { flex: 1; min-width: 0; font-family: 'JetBrains Mono', monospace; font-size: 13px; color: var(--gray-600); background: #fafafa; border: 1px solid #eaeaea; border-radius: 9px; padding: 12px 14px; word-break: break-all; white-space: normal; cursor: text; user-select: all; transition: all .15s; max-height: 120px; overflow-y: auto; }
    .token-display:hover { border-color: #d4d4d4; background: var(--white); box-shadow: 0 4px 12px rgba(0,0,0,.03); }
    .import-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 12px; }
    .textarea { width: 100%; font-family: 'JetBrains Mono', monospace; font-size: 13px; padding: 12px 14px; border: 1px solid #d4d4d4; border-radius: 9px; background: #fafafa; color: var(--black); outline: none; resize: none; transition: all .2s; }
    .textarea:hover { border-color: #a3a3a3; background: var(--white); }
    .textarea:focus { border-color: #3b82f6; background: var(--white); box-shadow: 0 0 0 3px rgba(59,130,246,0.15); }
    .danger-card { background: #fff1f2; border-color: #fca5a5; grid-column: 1 / -1; }
    .danger-card .card-title i { color: var(--red); background: #fee2e2; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; font-weight: 600; padding: 7px 14px; border-radius: 7px; cursor: pointer; transition: all .12s; border: none; }
    .btn-primary { background: var(--black); color: var(--white); }
    .btn-primary:hover { background: var(--gray-800); }
    .btn-secondary { background: var(--white); color: var(--gray-700); border: 1px solid var(--gray-200); }
    .btn-secondary:hover { background: var(--gray-50); border-color: var(--gray-400); }
    .btn-danger { background: var(--red); color: var(--white); }
    .btn-danger:hover { background: var(--red-dim); }
    .btn-ghost-sm { background: none; border: none; font-size: 11px; color: var(--gray-400); cursor: pointer; padding: 3px 7px; border-radius: 5px; display: flex; align-items: center; gap: 4px; transition: all .12s; }
    .btn-ghost-sm:hover { background: var(--gray-100); color: var(--black); }
    .msg-ok { color: var(--green); font-size: 12px; font-weight: 600; }
    .msg-err { color: var(--red); font-size: 12px; font-weight: 600; }

    /* Project view */
    .pv-header { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-bottom: 1px solid var(--gray-150); background: var(--white); flex-shrink: 0; }
    .pv-title { display: flex; align-items: center; gap: 10px; }
    .pv-name { font-size: 18px; font-weight: 800; }
    .pv-status-text { font-size: 11px; font-weight: 700; text-transform: uppercase; color: var(--gray-400); letter-spacing: .06em; }
    .pv-btns { display: flex; gap: 6px; }
    .pv-btn { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; padding: 6px 14px; border-radius: 7px; border: 1px solid var(--gray-200); background: var(--white); cursor: pointer; transition: all .12s; }
    .pv-btn.start:hover { border-color: var(--green); color: var(--green); background: #f0fdf4; }
    .pv-btn.restart:hover { border-color: #ca8a04; color: #78350f; background: #fefce8; }
    .pv-btn.stop:hover { border-color: var(--red); color: var(--red); background: var(--red-bg); }
    .pv-tabs { display: flex; padding: 0 20px; border-bottom: 1px solid var(--gray-150); background: var(--gray-50); flex-shrink: 0; gap: 0; }
    .ptab { font-size: 12px; font-weight: 500; padding: 9px 14px; cursor: pointer; background: none; border: none; border-bottom: 2px solid transparent; color: var(--gray-400); transition: all .15s; }
    .ptab.active { color: var(--black); border-bottom-color: var(--red); font-weight: 600; }
    .ptab:hover:not(.active) { color: var(--gray-600); }
    .pv-body { flex: 1; overflow: hidden; position: relative; }

    /* Project dashboard metrics */
    .metrics-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; padding: 24px; align-items: stretch; }
    .metric-card { background: var(--white); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; padding: 24px; box-shadow: 0 4px 16px rgba(0,0,0,0.02); transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: row; align-items: center; gap: 16px; }
    .metric-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.05); }
    .metric-icon { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
    .metric-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-400); margin-bottom: 4px; }
    .metric-val { font-size: 26px; font-weight: 800; font-family: 'JetBrains Mono', monospace; color: var(--black); line-height: 1.1; }
    .metric-val span { font-size: 14px; font-weight: 600; color: var(--gray-400); margin-left: 4px; }
    .metric-sub { font-size: 12px; font-weight: 600; color: var(--gray-500); margin-top: 6px; font-family: 'JetBrains Mono', monospace; }

    /* Project logs */
    .log-full { position: absolute; inset: 0; display: flex; flex-direction: column; background: #1a1a1a; }
    .log-full-head { display: flex; justify-content: space-between; align-items: center; padding: 9px 14px; border-bottom: 1px solid #2a2a2a; background: #212121; flex-shrink: 0; }
    .log-full-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #4b5563; display: flex; align-items: center; gap: 7px; }
    .log-full-stream { flex: 1; overflow-y: auto; padding: 10px 14px; font-family: 'JetBrains Mono', monospace; font-size: 11.5px; color: #d4d4d4; white-space: pre-wrap; word-break: break-all; line-height: 1.65; }
    .pulse-dot { display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--green); animation: pulseDot 2s infinite; }
    @keyframes pulseDot { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* Project settings form */
    .pv-settings { padding: 20px; overflow-y: auto; height: 100%; }
    .pv-settings-inner { max-width: 680px; }
    .form-section { margin-bottom: 20px; }
    .form-section-title { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--gray-500); margin-bottom: 10px; display: flex; align-items: center; gap: 6px; }
    .form-row { display: grid; gap: 10px; margin-bottom: 10px; }
    .form-row.cols-2 { grid-template-columns: 1fr 1fr; }
    .form-row.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
    .form-row.cols-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
    .form-field label { display: block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--gray-500); margin-bottom: 5px; }
    .exec-mode-group { display: flex; gap: 0; }
    .exec-mode-btn { flex: 1; font-size: 12px; font-weight: 600; padding: 8px 0; text-align: center; border: 1px solid var(--gray-200); background: var(--white); color: var(--gray-500); cursor: pointer; transition: all .12s; }
    .exec-mode-btn:first-child { border-radius: 7px 0 0 7px; }
    .exec-mode-btn:last-child { border-radius: 0 7px 7px 0; border-left: none; }
    .exec-mode-btn.selected { background: var(--black); color: var(--white); border-color: var(--black); }
    .toggles-row { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 4px; }
    /* Resource limit rows */
    .limit-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 12px; border: 1px solid var(--gray-150); border-radius: 9px; margin-bottom: 7px; gap: 12px; background: var(--white); transition: border-color .15s; }
    .limit-row:last-child { margin-bottom: 0; }
    .limit-left { display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0; }
    .limit-info { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
    .limit-name { font-size: 12px; font-weight: 600; color: var(--gray-700); }
    .limit-desc { font-size: 10px; color: var(--gray-400); }
    .limit-control { display: flex; align-items: center; gap: 6px; opacity: .35; pointer-events: none; transition: opacity .2s; }
    .limit-control.active { opacity: 1; pointer-events: all; }
    .limit-inp { width: 90px; text-align: right; }
    .limit-unit { width: 64px; padding: 8px 6px; cursor: pointer; }
    .limit-unit-label { font-size: 11px; font-weight: 600; color: var(--gray-400); white-space: nowrap; }
    .toggle-sm .toggle-track { width: 30px; height: 17px; }
    .toggle-sm .toggle-thumb { width: 11px; height: 11px; }
    input:checked ~ .toggle-track .toggle-thumb, .toggle-sm input:checked ~ .toggle-track .toggle-thumb { transform: translateX(13px); }

    /* Toggle switch */
    .toggle { display: inline-flex; align-items: center; gap: 8px; cursor: pointer; user-select: none; }
    .toggle input { display: none; }
    .toggle-track { width: 36px; height: 20px; background: var(--gray-200); border-radius: 10px; position: relative; transition: background .2s; flex-shrink: 0; }
    .toggle-thumb { position: absolute; top: 3px; left: 3px; width: 14px; height: 14px; background: var(--white); border-radius: 50%; transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
    .toggle input:checked + .toggle-track { background: var(--red); }
    .toggle input:checked + .toggle-track .toggle-thumb { transform: translateX(16px); }
    .toggle-label { font-size: 13px; font-weight: 500; color: var(--gray-700); }

    /* Ecosystem upload */
    .upload-zone { border: 1.5px dashed var(--gray-200); border-radius: 8px; padding: 14px; text-align: center; cursor: pointer; transition: all .15s; background: var(--gray-50); }
    .upload-zone:hover { border-color: var(--red); background: var(--red-bg); }
    .upload-zone.has-file { border-color: var(--green); background: #f0fdf4; }
    .upload-zone-text { font-size: 12px; color: var(--gray-400); }
    .upload-zone.has-file .upload-zone-text { color: var(--green); font-weight: 600; }

    /* Env file list (replaces chips) */
    .env-file-list { display: flex; flex-direction: column; gap: 3px; margin-bottom: 8px; }
    .env-file-row { border: 1px solid var(--gray-150); border-radius: 7px; overflow: hidden; transition: border-color .12s; }
    .env-file-row.active { border-color: #93c5fd; }
    .env-file-row-head { display: flex; align-items: center; gap: 8px; padding: 7px 10px; background: var(--white); }
    .env-file-row.active .env-file-row-head { background: #f0f7ff; }
    .env-file-toggle { width: 14px; height: 14px; accent-color: #2563eb; cursor: pointer; flex-shrink: 0; }
    .env-file-name { flex: 1; font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--gray-700); }
    .env-file-row.active .env-file-name { color: #1d4ed8; font-weight: 600; }
    .env-file-preview-btn { display: flex; align-items: center; gap: 3px; font-size: 10px; font-weight: 500; color: var(--gray-400); background: none; border: none; cursor: pointer; padding: 2px 7px; border-radius: 4px; transition: all .12s; white-space: nowrap; }
    .env-file-preview-btn:hover { background: var(--gray-100); color: var(--gray-700); }
    .env-file-remove { background: none; border: none; cursor: pointer; color: var(--gray-300); font-size: 15px; padding: 2px 4px; border-radius: 4px; line-height: 1; transition: color .12s; }
    .env-file-remove:hover { color: var(--red); }
    .env-file-preview { display: none; background: var(--gray-50); border-top: 1px solid var(--gray-150); font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gray-500); line-height: 1.8; max-height: 200px; overflow-y: auto; }
    .env-file-preview.open { display: block; }
    .env-import-row-btn { color: var(--gray-400); gap: 4px; }
    .env-import-row-btn:hover { color: var(--green) !important; border-color: #bbf7d0 !important; background: #f0fdf4 !important; }
    .env-file-preview-line { display: flex; gap: 8px; padding: 0 10px 0 32px; }
    .env-file-preview-key { color: #0e7490; min-width: 120px; flex-shrink: 0; }
    .env-file-preview-val { color: var(--gray-500); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .env-file-empty { font-size: 11px; color: var(--gray-300); font-style: italic; padding: 6px 0; }
    /* Env var editor */
    .env-vars-list { display: flex; flex-direction: column; gap: 5px; margin-bottom: 8px; }
    .env-var-row { display: grid; grid-template-columns: 1fr 1fr auto; gap: 5px; align-items: center; }
    .kv-input { font-family: 'JetBrains Mono', monospace; font-size: 12px; padding: 5px 9px; border: 1px solid var(--gray-200); border-radius: 6px; background: var(--white); color: var(--black); outline: none; width: 100%; transition: border-color .12s; }
    .kv-input:focus { border-color: var(--black); }
    .kv-del { background: none; border: none; cursor: pointer; color: var(--gray-300); font-size: 16px; line-height: 1; padding: 2px 5px; border-radius: 4px; transition: color .12s; flex-shrink: 0; }
    .kv-del:hover { color: var(--red); background: var(--red-bg); }
    /* Env file tag (selected list) */
    .env-file-tag { display: inline-flex; align-items: center; gap: 5px; font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 3px 8px; border-radius: 5px; background: var(--gray-100); border: 1px solid var(--gray-200); color: var(--gray-700); }
    .env-file-tag button { background: none; border: none; cursor: pointer; color: var(--gray-400); font-size: 13px; line-height: 1; padding: 0 1px; display: flex; align-items: center; transition: color .12s; }
    .env-file-tag button:hover { color: var(--red); }

    /* Add project modal */
    .modal-backdrop { position: fixed; inset: 0; z-index: 50; display: none; align-items: center; justify-content: center; background: rgba(0,0,0,.5); backdrop-filter: blur(3px); }
    .modal-backdrop.open { display: flex; }
    .modal { background: var(--white); border-radius: 16px; border: 1px solid var(--gray-150); box-shadow: 0 20px 60px rgba(0,0,0,.15); width: 100%; max-width: 500px; margin: 16px; overflow: hidden; animation: slideUp .22s ease; display: flex; flex-direction: column; max-height: calc(100vh - 32px); }
    .modal-lg { max-width: 640px; }
    .modal-head { display: flex; align-items: center; justify-content: space-between; padding: 14px 18px; border-bottom: 1px solid var(--gray-100); background: var(--gray-50); }
    .modal-title { font-size: 14px; font-weight: 700; }
    .modal-close { width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--gray-200); background: var(--white); cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--gray-400); transition: all .12s; }
    .modal-close:hover { background: var(--gray-100); color: var(--black); }
    .modal-body { padding: 18px; overflow-y: auto; flex: 1; min-height: 0; }
    .modal-footer { padding: 12px 18px; border-top: 1px solid var(--gray-100); background: var(--white); flex-shrink: 0; }
    /* Add modal step 1 — dir picker */
    .add-dir-step { padding: 20px 18px 16px; border-bottom: 1px solid var(--gray-100); flex-shrink: 0; background: var(--white); }
    .add-dir-detected { display: flex; align-items: center; gap: 8px; margin-top: 8px; font-size: 12px; color: var(--green); font-weight: 500; }
    .add-dir-detected svg { flex-shrink: 0; }
    /* Form detail section (step 2) */
    .add-detail-step { display: none; }
    .add-detail-step.visible { display: block; animation: fadeIn .18s ease; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
    .modal-foot { display: flex; gap: 8px; padding: 14px 18px; border-top: 1px solid var(--gray-100); background: var(--gray-50); }
    .confirm-modal { max-width: 380px; }
    @keyframes slideUp { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

    /* Folder browser */
    .browser-path { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--gray-600); background: var(--gray-100); padding: 8px 12px; border-radius: 6px; margin-bottom: 8px; border: 1px solid var(--gray-200); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .browser-list { flex: 1; overflow-y: auto; }
    .browser-item { display: flex; align-items: center; gap: 9px; padding: 8px 10px; border-radius: 7px; cursor: pointer; color: var(--gray-700); font-size: 12px; font-family: 'JetBrains Mono', monospace; transition: all .12s; }
    .browser-item:hover { background: var(--gray-100); color: var(--black); }
    .browser-item.parent { font-weight: 700; color: var(--gray-400); }
    .browser-item svg { color: var(--gray-400); flex-shrink: 0; }

    /* Custom dropdown */
    .dropdown-wrap { position: relative; }
    .dropdown-btn { width: 100%; text-align: left; font-size: 13px; padding: 8px 12px; border: 1px solid var(--gray-200); border-radius: 7px; background: var(--white); color: var(--black); cursor: pointer; display: flex; align-items: center; justify-content: space-between; transition: border-color .12s; font-family: inherit; }
    .dropdown-btn:hover { border-color: var(--gray-400); }
    .dropdown-menu { position: absolute; z-index: 30; width: 100%; top: calc(100% - 60px); background: var(--white); border: 1px solid var(--gray-200); border-radius: 9px; box-shadow: 0 8px 24px rgba(0,0,0,.1); overflow: hidden; display: none; }
    .dropdown-menu.open { display: block; }
    .dropdown-item { display: flex; align-items: center; gap: 8px; width: 100%; padding: 8px 12px; font-size: 13px; font-weight: 500; color: var(--gray-700); background: transparent; border: none; border-radius: 6px; cursor: pointer; text-align: left; transition: all 0.2s; }
    .dropdown-item:hover { background: var(--gray-100); color: var(--gray-900); }
    .dropdown-item i { font-size: 14px; }
    .dropdown-opt { padding: 8px 12px; font-size: 13px; cursor: pointer; color: var(--gray-700); transition: background .1s; }
    .dropdown-opt:hover { background: var(--gray-50); color: var(--black); }

    /* Toast */
    .toast { position: fixed; top: 20px; right: 20px; z-index: 100; font-size: 13px; font-weight: 500; padding: 12px 18px; border-radius: 9px; box-shadow: 0 6px 20px rgba(0,0,0,.15); border: 1px solid; display: none; align-items: center; gap: 8px; max-width: 340px; animation: slideDownToast .3s ease; }
    .toast.show { display: flex !important; }
    .toast-ok { background: #f0fdf4; color: #166534; border-color: #bbf7d0; }
    .toast-err { background: #fef2f2; color: #991b1b; border-color: #fca5a5; }
    .toast-info { background: #eff6ff; color: #1e40af; border-color: #bfdbfe; }
    .toast-warn { background: #fffbeb; color: #92400e; border-color: #fde68a; }
    .toast i { font-size: 16px; flex-shrink: 0; }
    @keyframes slideDownToast { from{opacity:0;transform:translateY(-15px)} to{opacity:1;transform:translateY(0)} }

    /* Misc */
    .empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; color: var(--gray-400); padding: 40px; }
    .empty-state svg { opacity: .3; }
    .flex-center { display: flex; align-items: center; }
    .gap-2 { gap: 8px; }
    .hidden { display: none !important; }
    .w-full { width: 100%; }
  </style>
</head>
<body>
<div class="layout">

  <!-- TOP BAR -->
  <header class="topbar">
    <div class="topbar-left">
      <div class="dropdown-wrap" style="position:relative;">
        <div style="display:flex; align-items:center; gap:8px; cursor:pointer;" onclick="toggleDropdown('titleMenu')">
          <div class="topbar-logo" style="width:24px; height:24px;">
            <svg fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm3.293 1.293a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 01-1.414-1.414L7.586 10 5.293 7.707a1 1 0 010-1.414zM11 12a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/></svg>
          </div>
          <span class="topbar-title" id="topbarTitle" style="font-weight:700;">Project CLI</span>
          <i class="bi bi-chevron-down" style="font-size:10px; color:var(--gray-400);"></i>
        </div>
        <div class="dropdown-menu" id="titleMenu" style="left:0; top:calc(100% + 12px); width:200px; padding:6px;">
          <div style="padding: 10px 12px; border-bottom: 1px solid var(--gray-100);">
            <div style="font-size:11px; font-weight:600; color:var(--gray-400); text-transform:uppercase; letter-spacing:0.5px;">Namespace</div>
            <div style="font-size:12px; font-weight:700; color:var(--gray-800); margin-top:2px;" id="navPkgMenu">—</div>
          </div>
          <button class="dropdown-item" onclick="setMainTab('cloud')">
            <i class="bi bi-cloud" style="margin-right:8px; color:var(--gray-500);"></i> File Management
          </button>
          <button class="dropdown-item" onclick="setMainTab('settings')">
            <i class="bi bi-gear" style="margin-right:8px; color:var(--gray-500);"></i> App Settings
          </button>
          <button class="dropdown-item" onclick="openRamModal()">
            <i class="bi bi-cpu" style="margin-right:8px; color:var(--gray-500);"></i> Clean RAM
          </button>
        </div>
      </div>
      <span class="topbar-pkg mono" id="navPkg" style="margin-left: 8px;">—</span>
    </div>
    <div class="topbar-right">
      <span class="badge" id="pm2Badge"><span class="dot"></span>CLI</span>
      <div style="display:flex; align-items:center; cursor:pointer;" onclick="openRamModal()">
        <span class="sysinfo sysinfo-hover" id="sysInfo">—</span>
      </div>
      <button class="btn-ghost" onclick="setMainTab('settings')">⚙ App Settings</button>
      <button class="btn-ghost" onclick="logout()">Sign out</button>
    </div>
  </header>

  <div id="ramModal" class="modal-backdrop">
    <div class="modal modal-lg" style="width:600px; max-width:90%">
      <div class="modal-head">
        <h2 class="modal-title">Quản Lý RAM Khẩn Cấp ⚡</h2>
        <button class="modal-close" onclick="closeRamModal()">×</button>
      </div>
      <div class="modal-body" style="padding:0;">
        <div style="padding:16px 20px; border-bottom:1px solid var(--gray-150); background:#f8fafc">
          <div style="font-size:12px; font-weight:700; color:var(--gray-500); text-transform:uppercase; margin-bottom:8px;">Dọn dẹp nhanh PM2 (Node.js)</div>
          <div style="display:flex; gap:10px;">
            <button onclick="cleanRam('reload')" class="btn-ghost" style="flex:1; background:white; border:1px solid var(--gray-200); padding:10px; display:flex; align-items:center; gap:8px;" onmouseover="this.style.borderColor='var(--blue-500)'" onmouseout="this.style.borderColor='var(--gray-200)'">
              <i class="bi bi-recycle" style="color:var(--blue-500)"></i> Reload Ẩn (Xả Leak)
            </button>
            <button onclick="cleanRam('flush')" class="btn-ghost" style="flex:1; background:white; border:1px solid var(--gray-200); padding:10px; display:flex; align-items:center; gap:8px;" onmouseover="this.style.borderColor='var(--red)'" onmouseout="this.style.borderColor='var(--gray-200)'">
              <i class="bi bi-eraser" style="color:var(--red)"></i> Xoá Cache Log PM2
            </button>
          </div>
        </div>
        <div style="padding:16px 20px 20px;">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
            <div style="font-size:12px; font-weight:700; color:var(--gray-500); text-transform:uppercase;">Tiến trình hệ thống đang ngậm RAM</div>
            <button onclick="loadRamProcesses()" class="btn-ghost" style="font-size:11px; padding:2px 6px;"><i class="bi bi-arrow-clockwise"></i> Load lại</button>
          </div>
          <div id="procList" style="border:1px solid var(--gray-150); border-radius:8px; background:white;">
            <div style="padding:20px; text-align:center; color:var(--gray-400); font-size:12px;">Đang quét RAM máy...</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="body-row">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-head">
        <div class="sidebar-head-tabs">
          <button class="stab active" id="stab-projects" onclick="setSideTab('projects')">Projects</button>
          <button class="stab" id="stab-logs" onclick="setSideTab('logs')">Live Logs</button>
        </div>
      </div>
      <div class="sidebar-body">

        <!-- Projects panel -->
        <div class="spanel active" id="spanel-projects">
          <div class="add-btn-wrap">
            <button class="add-btn" onclick="openAddModal()">
              <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
              Add Project
            </button>
          </div>
          <div id="projectList"></div>
          <div id="projectEmpty" class="empty-state hidden">
            <svg width="32" height="32" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
            <span style="font-size:11px">No projects configured</span>
          </div>
        </div>

        <!-- Global Logs panel -->
        <div class="spanel" id="spanel-logs">
          <div class="log-panel">
            <div class="log-head">
              <span class="log-label">Live PM2 Logs</span>
              <button class="btn-ghost-sm" onclick="clearGlobalLog()">Clear</button>
            </div>
            <pre class="log-box" id="globalLogStream"></pre>
          </div>
        </div>



      </div>
    </aside>

    <!-- MAIN -->
    <main class="main">

      <!-- Tabs -->
      <div class="main-tabs">
        <button class="mtab active" id="mtab-overview" onclick="setMainTab('overview')">Overview</button>
        <button class="mtab" id="mtab-settings" onclick="setMainTab('settings')">App Settings</button>
        <button class="mtab" id="mtab-cloud" onclick="setMainTab('cloud')">File Management</button>
        <div class="tab-sep"></div>
        <button class="mtab project-tab hidden" id="mtab-project" onclick="setMainTab('project')">
          <span id="mtab-project-label">Project</span>
        </button>
        <div class="main-actions">
          <button class="action-btn start-all" onclick="runAction('start-all')">
            <span class="pulse-dot" style="width:6px;height:6px;"></span> Start All
          </button>
          <button class="action-btn" onclick="runAction('restart-all')">
            <i class="bi bi-arrow-clockwise"></i> Restart All
          </button>
          <button class="action-btn stop-all" onclick="runAction('stop-all')">■ Stop All</button>
        </div>
      </div>

      <!-- ─── OVERVIEW PANEL ─── -->
      <div class="panel active" id="mpanel-overview">
        <div class="overview-grid" id="overviewGrid"></div>
      </div>

      <!-- ─── APP SETTINGS PANEL ─── -->
      <div class="panel" id="mpanel-settings">
        <div class="settings-scroll">
          <div class="settings-inner">

            <!-- Account -->
            <div class="card">
              <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px">
                <div class="card-title" style="margin:0">
                  <i class="bi bi-shield-lock"></i>
                  Account & Security
                </div>
                <div class="dropdown-wrap" style="position:relative;">
                  <button class="btn-ghost-sm" onclick="toggleDropdown('settingsMenu')" title="Settings" style="padding:6px 10px; font-size:16px; color:var(--gray-500); cursor:pointer;">
                    <i class="bi bi-gear"></i>
                  </button>
                  <div class="dropdown-menu" id="settingsMenu" style="right:0; top:calc(100% + 8px); width:180px; padding:6px;">
                    <input type="file" id="logoUploadInput" accept="image/*" style="display:none" onchange="uploadEnterpriseLogo(event)" />
                    <button class="dropdown-item" onclick="document.getElementById('logoUploadInput').click()">
                      <i class="bi bi-image" style="margin-right:8px; color:var(--gray-500);"></i> Change Logo
                    </button>
                    <button class="dropdown-item" onclick="removeEnterpriseLogo()">
                      <i class="bi bi-x-circle" style="margin-right:8px; color:var(--red);"></i> Remove Logo
                    </button>
                    <button class="dropdown-item" onclick="document.getElementById('pwdFormWrapper').classList.toggle('hidden'); toggleDropdown('settingsMenu');">
                      <i class="bi bi-lock" style="margin-right:8px; color:var(--gray-500);"></i> Change Password
                    </button>
                  </div>
                </div>
              </div>
              <div class="info-grid">
                <div class="info-cell"><div class="info-label">Username</div><div class="info-val" id="s-username">—</div></div>
                <div class="info-cell"><div class="info-label">Organization</div><div class="info-val" id="s-org">—</div></div>
                <div class="info-cell"><div class="info-label">CLI Command</div><div class="info-val mono" id="s-cli">—</div></div>
                <div class="info-cell"><div class="info-label">Created At</div><div class="info-val" id="s-created">—</div></div>
              </div>
              
              <div style="font-size:11px; text-align:right; color:var(--gray-500); margin-top:8px" id="logoUploadMsg"></div>

              <div id="pwdFormWrapper" class="hidden pwd-form-wrap" style="margin-top:20px; padding-top:20px; border-top:1px solid var(--gray-100)">
                <div class="sec-title" style="margin-bottom:16px">Change Password</div>
                <div class="input-row" style="margin-bottom:16px">
                  <input class="inp" id="curPwd" type="password" placeholder="Current password">
                  <input class="inp" id="newPwd" type="password" placeholder="New password (min 8)">
                  <input class="inp" id="confirmNewPwd" type="password" placeholder="Confirm new password">
                </div>
                <div style="display:flex;align-items:center;gap:12px;justify-content:flex-end">
                  <span id="pwdMsg" class="hidden"></span>
                  <button class="btn btn-primary" onclick="changePwd()">Update Password</button>
                </div>
              </div>
            </div>

            <!-- API Token -->
            <div class="card">
              <div class="card-title"><i class="bi bi-key"></i> API Token</div>
              <p style="font-size:11px;color:var(--gray-400);margin-bottom:10px">JWT token expires in 7 days. Use for external API calls.</p>
              <div class="token-row">
                <div class="token-display" id="tokenDisplay">—</div>
                <button class="btn btn-secondary" onclick="copyToken()">Copy</button>
              </div>
            </div>

            <!-- Import Ecosystem Config -->
            <div class="card full-span">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                <div class="card-title" style="margin:0"><i class="bi bi-file-earmark-code"></i> Import ecosystem.config.js</div>
                <button class="btn-ghost-sm" onclick="loadPm2Config()">
                  <i class="bi bi-arrow-clockwise"></i> Refresh
                </button>
              </div>
              <p style="font-size:11px;color:var(--gray-400);margin-bottom:12px">Paste an existing ecosystem config to bulk-import all projects.</p>
              <div class="import-grid">
                <div>
                  <p style="font-size:11px;font-weight:600;color:var(--gray-600);margin-bottom:6px">Current Config</p>
                  <textarea class="textarea" id="pm2ConfigView" style="height:160px" readonly></textarea>
                </div>
                <div>
                  <p style="font-size:11px;font-weight:600;color:var(--gray-600);margin-bottom:6px">Import Config</p>
                  <textarea class="textarea" id="importConfigArea" style="height:160px" placeholder="Paste module.exports = { apps: [...] } here…"></textarea>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:10px;margin-top:10px">
                <button class="btn btn-primary" onclick="importConfig()">Merge & Import</button>
                <span id="importMsg" class="hidden"></span>
              </div>
            </div>

            <!-- Danger Zone -->
            <div class="card danger-card full-span">
              <div class="card-title" style="color:var(--red);border-left:none;">
                <i class="bi bi-exclamation-triangle"></i>
                Danger Zone
              </div>
              <p style="font-size:12px;color:var(--red);margin-bottom:14px;line-height:1.5">Immediately stops all processes, deletes all configurations, and resets to factory default. <strong>This cannot be undone.</strong></p>
              <button class="btn btn-danger" onclick="confirmReset()">Wipe Everything & Reset</button>
            </div>

          </div>
        </div>
      </div>

      <!-- ─── FILE MANAGEMENT PANEL (CLOUD) ─── -->
      <div class="panel" id="mpanel-cloud">
        <div class="settings-scroll">
          <div style="padding: 24px;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
              <div>
                <h1 style="font-size:20px; font-weight:700; color:var(--gray-900);">Cloud Storage</h1>
                <p style="font-size:13px; color:var(--gray-500); margin-top:4px;">Shared images and assets</p>
              </div>
              <div>
                <input type="file" id="cloudUploadInput" multiple accept="image/*" style="display:none" onchange="uploadCloudFiles(event)" />
                <button class="btn btn-primary" style="display:flex; align-items:center; gap:8px;" onclick="document.getElementById('cloudUploadInput').click()">
                  <i class="bi bi-plus-lg"></i> Upload Files
                </button>
              </div>
            </div>
            
            <div id="cloudLoading" style="display:none; text-align:center; padding: 40px; color:var(--gray-400);">Loading...</div>
            
            <div id="cloudEmpty" style="display:none; text-align:center; padding: 60px 20px; background:var(--white); border-radius:12px; border:1px solid var(--gray-150);">
              <i class="bi bi-image" style="font-size:32px; color:var(--gray-300); margin-bottom:12px; display:block;"></i>
              <h3 style="font-size:14px; font-weight:700; margin-bottom:4px;">No files found</h3>
              <p style="font-size:12px; color:var(--gray-500); margin-bottom:16px;">Start by uploading your first image</p>
              <button class="btn-ghost" style="background:var(--gray-900); color:white;" onclick="document.getElementById('cloudUploadInput').click()">Upload File</button>
            </div>

            <div id="cloudGrid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
              <!-- Grid items rendered here -->
            </div>
          </div>
        </div>
      </div>

      <!-- ─── PROJECT VIEW PANEL ─── -->
      <div class="panel" id="mpanel-project">
        <div class="pv-header">
          <div class="pv-title">
            <div class="dot-status dot-stopped" id="pv-dot"></div>
            <h2 class="pv-name" id="pv-name">—</h2>
            <span class="pv-status-text" id="pv-status-text" style="transition: color 0.2s">stopped</span>
          </div>
          <div class="pv-btns">
            <button class="pv-btn start" onclick="runAction('start', currentSelectedProject)">▶ Start</button>
            <button class="pv-btn restart" onclick="runAction('restart', currentSelectedProject)">↺ Restart</button>
            <button class="pv-btn stop" onclick="runAction('stop', currentSelectedProject)">■ Stop</button>
          </div>
        </div>
        <div class="pv-tabs">
          <button class="ptab active" id="ptab-dashboard" onclick="setProjectSubTab('dashboard')">Dashboard</button>
          <button class="ptab" id="ptab-logs" onclick="setProjectSubTab('logs')">Logs</button>
          <button class="ptab" id="ptab-terminal" onclick="setProjectSubTab('terminal')">Terminal</button>
          <button class="ptab" id="ptab-config" onclick="setProjectSubTab('config')">Project Settings</button>
        </div>
        <div class="pv-body">

          <!-- Project Dashboard -->
          <div id="pview-dashboard" style="overflow-y:auto;height:100%">
            <div class="metrics-grid" id="pv-metrics" style="padding-bottom:12px;"></div>
            
            <div style="padding: 0 24px 24px; display: grid; grid-template-columns: 2fr 1fr; gap: 20px;">
              <!-- Main Performance Chart -->
              <div class="card" style="padding:24px; display:flex; flex-direction:column; height:320px;">
                <div style="display:flex; justify-content:space-between; width:100%; margin-bottom:16px;">
                  <div>
                    <div style="font-size:15px; font-weight:700; color:var(--black); margin-bottom:4px"><i class="bi bi-graph-up-arrow" style="color:#3b82f6;margin-right:6px"></i> Performance Real-time</div>
                    <div style="font-size:12px; color:var(--gray-400)">CPU (purple) &amp; Memory (orange) Timeline</div>
                  </div>
                </div>
                <div style="flex:1; width:100%; position:relative;">
                  <canvas id="perfChart"></canvas>
                </div>
              </div>

              <!-- Health Assessment & Traffic -->
              <div style="display:flex; flex-direction:column; gap:20px;">
                <!-- Health Score -->
                <div class="card" style="padding:24px; display:flex; flex-direction:column; justify-content:center; flex:1">
                  <div style="font-size:13px; font-weight:700; color:var(--gray-500); text-transform:uppercase; letter-spacing:.05em; margin-bottom:12px;"><i class="bi bi-heart-pulse-fill" style="color:#ef4444;margin-right:4px"></i> App Health Index</div>
                  <div style="display:flex; align-items:flex-end; gap:8px; margin-bottom:12px;">
                    <div style="font-size:48px; font-weight:800; line-height:1; color:#22c55e" id="hlthScore">100</div>
                    <div style="font-size:16px; font-weight:700; color:var(--gray-400); padding-bottom:6px;">/ 100</div>
                  </div>
                  <div style="font-size:13px; color:var(--gray-500); line-height:1.5" id="hlthText">Cấu trúc tải trọng cực kỳ lý tưởng.</div>
                </div>
                <!-- Traffic -->
                <div class="card" style="padding:24px; display:flex; flex-direction:column; justify-content:center;">
                  <div style="font-size:13px; font-weight:700; color:var(--gray-500); text-transform:uppercase; letter-spacing:.05em; margin-bottom:16px;"><i class="bi bi-globe2" style="color:#8b5cf6;margin-right:4px"></i> Network Traffic</div>
                  <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
                    <div>
                      <div style="font-size:11px; color:var(--gray-400); font-weight:600; text-transform:uppercase; margin-bottom:2px">Simulated Req</div>
                      <div style="font-size:22px; font-weight:800; color:var(--black)" id="reqTotal">N/A</div>
                    </div>
                    <div style="text-align:right">
                      <div style="font-size:11px; color:var(--gray-400); font-weight:600; text-transform:uppercase; margin-bottom:2px">Avg Latency</div>
                      <div style="font-size:22px; font-weight:800; color:#3b82f6" id="reqLatency">—</div>
                    </div>
                  </div>
                  <div style="font-size:11px; color:var(--gray-400); font-style:italic">* Integrates PM2 APM Metrics module.</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Project Logs -->
          <div id="pview-logs" class="log-full hidden">
            <div class="log-full-head">
              <span class="log-full-label"><span class="pulse-dot"></span>Streaming Logs</span>
              <button class="btn-ghost-sm" style="color:#4b5563" onclick="clearProjectLogs()">Clear</button>
            </div>
            <div class="log-full-stream" id="pv-logStream"></div>
          </div>

          <!-- Project Terminal -->
          <div id="pview-terminal" class="term-wrap hidden" style="margin:20px; height:calc(100% - 40px)">
            <div class="term-out" id="termOutput"></div>
            <div class="term-in">
              <span class="term-prompt">❯</span>
              <input type="text" class="term-input" id="termInput" placeholder="Enter shell command…" onkeydown="handleKey(event)">
              <button class="term-btn" onclick="clearTerm()">
                <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/></svg> Clear
              </button>
            </div>
          </div>

          <!-- Project Settings -->
          <div id="pview-config" class="hidden pv-settings">
            <div class="pv-settings-inner">
              <form id="editForm" onsubmit="submitEditProject(event)">

                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    Directory
                  </div>
                  <div class="form-row">
                    <div class="form-field">
                      <label>Working Directory (cwd) *</label>
                      <input class="inp mono w-full" id="p-cwd" required placeholder="/path/to/project">
                    </div>
                  </div>
                </div>

                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/></svg>
                    Run Command
                  </div>
                  <div class="form-row cols-2">
                    <div class="form-field">
                      <label>Script</label>
                      <input class="inp mono w-full" id="p-script" placeholder="npm">
                    </div>
                    <div class="form-field">
                      <label>Arguments</label>
                      <input class="inp mono w-full" id="p-args" placeholder="run dev">
                    </div>
                  </div>
                </div>

                <!-- Source Env Files -->
                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                    Source Env Files
                    <span style="font-weight:400;font-size:10px;color:var(--gray-400);text-transform:none;margin-left:4px">Phát hiện file .env trong thư mục — Preview và import vào PM2 env</span>
                  </div>
                  <div id="p-env-file-list" class="env-file-list">
                    <span class="env-file-empty">Chưa phát hiện file .env nào</span>
                  </div>
                </div>

                <!-- Environment Variables -->
                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
                    Environment Variables
                    <span style="font-weight:400;font-size:10px;color:var(--gray-400);text-transform:none;margin-left:4px">Truyền thẳng vào process (PM2 env)</span>
                  </div>
                  <div id="p-env-vars-list" class="env-vars-list"></div>
                  <button type="button" class="btn-ghost-sm" onclick="addEnvVarRow('','',false)" style="font-size:12px">
                    <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Add Variable
                  </button>
                </div>

                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                    Process Mode
                  </div>
                  <div class="form-row cols-2">
                    <div class="form-field">
                      <label>Execution Mode</label>
                      <div class="exec-mode-group">
                        <button type="button" class="exec-mode-btn selected" id="em-fork" onclick="setExecMode('fork')">Fork</button>
                        <button type="button" class="exec-mode-btn" id="em-cluster" onclick="setExecMode('cluster')">Cluster</button>
                      </div>
                      <input type="hidden" id="p-exec-mode" value="fork">
                    </div>
                    <div class="form-field" id="instances-field">
                      <label>Workers (instances)</label>
                      <input class="inp mono w-full" id="p-instances" type="number" min="1" placeholder="1" value="1">
                    </div>
                  </div>
                </div>

                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                    Resource Limits & Timing
                  </div>

                  <!-- Max Memory -->
                  <div class="limit-row">
                    <div class="limit-left">
                      <label class="toggle toggle-sm">
                        <input type="checkbox" id="p-max-memory-on" onchange="toggleLimitField('max-memory')">
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                      </label>
                      <div class="limit-info">
                        <span class="limit-name">Max Memory Restart</span>
                        <span class="limit-desc">Tự restart khi dùng quá giới hạn RAM</span>
                      </div>
                    </div>
                    <div class="limit-control" id="limit-control-max-memory">
                      <input type="number" id="p-max-memory-val" class="inp mono limit-inp" placeholder="512" min="1">
                      <select id="p-max-memory-unit" class="inp limit-unit">
                        <option value="M">MB</option>
                        <option value="G">GB</option>
                      </select>
                    </div>
                  </div>

                  <!-- Kill Timeout -->
                  <div class="limit-row">
                    <div class="limit-left">
                      <label class="toggle toggle-sm">
                        <input type="checkbox" id="p-kill-timeout-on" onchange="toggleLimitField('kill-timeout')">
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                      </label>
                      <div class="limit-info">
                        <span class="limit-name">Kill Timeout</span>
                        <span class="limit-desc">Thời gian chờ trước khi force kill (ms)</span>
                      </div>
                    </div>
                    <div class="limit-control" id="limit-control-kill-timeout">
                      <input type="number" id="p-kill-timeout-val" class="inp mono limit-inp" placeholder="3000" min="0" step="500">
                      <span class="limit-unit-label">ms</span>
                    </div>
                  </div>

                  <!-- Restart Delay -->
                  <div class="limit-row">
                    <div class="limit-left">
                      <label class="toggle toggle-sm">
                        <input type="checkbox" id="p-restart-delay-on" onchange="toggleLimitField('restart-delay')">
                        <span class="toggle-track"><span class="toggle-thumb"></span></span>
                      </label>
                      <div class="limit-info">
                        <span class="limit-name">Restart Delay</span>
                        <span class="limit-desc">Chờ trước khi restart sau khi crash (ms)</span>
                      </div>
                    </div>
                    <div class="limit-control" id="limit-control-restart-delay">
                      <input type="number" id="p-restart-delay-val" class="inp mono limit-inp" placeholder="0" min="0" step="500">
                      <span class="limit-unit-label">ms</span>
                    </div>
                  </div>
                </div>

                <div class="form-section">
                  <div class="form-section-title">Options</div>
                  <div class="toggles-row">
                    <label class="toggle">
                      <input type="checkbox" id="p-autorestart">
                      <span class="toggle-track"><span class="toggle-thumb"></span></span>
                      <span class="toggle-label">Auto Restart</span>
                    </label>
                    <label class="toggle">
                      <input type="checkbox" id="p-watch">
                      <span class="toggle-track"><span class="toggle-thumb"></span></span>
                      <span class="toggle-label">Watch Mode</span>
                    </label>
                  </div>
                </div>

                <div class="form-section">
                  <div class="form-section-title">
                    <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
                    Upload Ecosystem Config
                  </div>
                  <input type="file" id="ecoFileInput" accept=".js,.json" style="display:none" onchange="handleEcoFileSelect(event)">
                  <div class="upload-zone" id="uploadZone" onclick="document.getElementById('ecoFileInput').click()">
                    <span class="upload-zone-text" id="uploadZoneText">Click to upload ecosystem.config.js — config will be merged automatically</span>
                  </div>
                  <div style="display:flex;gap:8px;margin-top:8px">
                    <button type="button" class="btn btn-secondary" id="ecoUploadBtn" onclick="uploadProjectEcosystem()" style="display:none">Upload & Sync</button>
                    <button type="button" class="btn-ghost-sm" id="ecoViewBtn" onclick="viewProjectEcosystem()" style="display:none">View current file</button>
                  </div>
                </div>

                <div style="padding-top:4px;border-top:1px solid var(--gray-100);margin-top:4px;display:flex;align-items:center;gap:10px">
                  <button type="submit" class="btn btn-primary">Save Project Settings</button>
                  <span id="editMsg" class="hidden"></span>
                </div>
              </form>
            </div>
          </div>

        </div>
      </div>

    </main>
  </div>
</div>

<!-- ─── ADD PROJECT MODAL ─── -->
<div id="addModal" class="modal-backdrop">
  <div class="modal modal-lg">

    <!-- Header -->
    <div class="modal-head">
      <span class="modal-title">Add Project</span>
      <button class="modal-close" onclick="closeModal('addModal')">
        <svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <!-- Step 1: Directory (always visible, sticky) -->
    <div class="add-dir-step">
      <label style="display:block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--gray-500);margin-bottom:6px">
        <svg width="11" height="11" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="display:inline-block;vertical-align:-1px;margin-right:4px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        Target Directory *
      </label>
      <div style="display:flex;gap:6px">
        <input id="f-cwd" required placeholder="/Users/dev/my-app" class="inp mono" style="flex:1"
          onblur="onCwdChange(this.value)" onkeydown="if(event.key==='Enter'){event.preventDefault();onCwdChange(this.value)}">
        <button type="button" class="btn btn-secondary" onclick="openFolderBrowser()">
          <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
          Browse
        </button>
      </div>
      <div id="f-dir-status" style="margin-top:7px;font-size:11px;color:var(--gray-400)">Chọn thư mục để tự động phát hiện framework &amp; file env.</div>
    </div>

    <!-- Step 2: Details (revealed after dir selected) -->
    <div class="modal-body add-detail-step" id="addDetailStep">
      <form id="addForm" onsubmit="submitProject(event)">

