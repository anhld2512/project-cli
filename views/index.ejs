// ─── Project CRUD ───
async function runAction(action, name) {
  const r = await api('POST', '/api/action', { action, name });
  if (r.error) toast(r.error, 'err');
  else { toast('Done.', 'ok'); loadProjects(); }
}

function deleteProject(name) {
  showConfirm(
    'Delete Project',
    `Remove configuration for "${name}"? The project will be stopped and removed.`,
    async () => {
      const r = await api('DELETE', `/api/projects/${encodeURIComponent(name)}`);
      if (r.error) { toast(r.error, 'err'); return; }
      toast(`Removed "${name}"`, 'ok');
      // If it was selected, clear the view
      if (currentSelectedProject === name) {
        currentSelectedProject = null;
        document.getElementById('mtab-project').classList.add('hidden');
      }
      await loadProjects();
      if (!currentSelectedProject) setMainTab('overview');
    },
    true
  );
}

async function submitEditProject(e) {
  e.preventDefault();
  const p = projects.find(x => x.name === currentSelectedProject);
  if (!p) return;
  const body = {
    ...p,
    cwd: document.getElementById('p-cwd').value.trim(),
    script: document.getElementById('p-script').value.trim() || 'npm',
    args: document.getElementById('p-args').value.trim() || 'run dev',
    env: getEnvVars(false),
    autorestart: document.getElementById('p-autorestart').checked,
    watch: document.getElementById('p-watch').checked,
    exec_mode: document.getElementById('p-exec-mode').value,
    instances: parseInt(document.getElementById('p-instances').value) || 1,
    max_memory_restart: document.getElementById('p-max-memory-on').checked
      ? (document.getElementById('p-max-memory-val').value || '512') + document.getElementById('p-max-memory-unit').value
      : undefined,
    kill_timeout: document.getElementById('p-kill-timeout-on').checked
      ? (parseInt(document.getElementById('p-kill-timeout-val').value) || 3000)
      : undefined,
    restart_delay: document.getElementById('p-restart-delay-on').checked
      ? (parseInt(document.getElementById('p-restart-delay-val').value) || 0)
      : undefined,
  };
  // Clean undefined fields
  Object.keys(body).forEach(k => body[k] === undefined && delete body[k]);
  const r = await api('POST', '/api/projects', body);
  const msg = document.getElementById('editMsg');
  msg.classList.remove('hidden');
  if (r.success) {
    // If project is online, restart to apply new settings
    const wasOnline = p.status === 'online';
    if (wasOnline) {
      msg.textContent = '↺ Saving & restarting…'; msg.className = 'msg-ok';
      await api('POST', '/api/action', { action: 'restart', name: p.name });
      msg.textContent = '✓ Saved & restarted';
    } else {
      msg.textContent = '✓ Settings saved';
    }
    msg.className = 'msg-ok';
    loadProjects();
    setTimeout(() => msg.classList.add('hidden'), 3000);
  } else {
    msg.textContent = r.error || 'Error saving'; msg.className = 'msg-err';
  }
}

// ─── Env Files & Variables ───

// ── Env File List (row-based with inline preview) ──
let _envFileCwd = '';      // cwd for project settings
let _envFileCwdModal = ''; // cwd for add modal

function _buildEnvFileRows(files, cwd, isModal) {
  const prefix = isModal ? 'f' : 'p';
  return files.map(f => {
    const cwdEnc = encodeURIComponent(cwd);
    const canRemove = !_envFileScanCache(isModal).includes(f); // custom-added files
    const removeBtn = `<button type="button" class="env-file-remove" onclick="removeEnvFileRow('${esc(f)}',${isModal})" title="Remove">×</button>`;
    return `<div class="env-file-row" id="ef-row-${prefix}-${esc(f)}">
      <div class="env-file-row-head">
        <span class="env-file-name">${esc(f)}</span>
        <button type="button" class="env-file-preview-btn"
          onclick="toggleEnvPreview(this,'${cwdEnc}','${esc(f)}',${isModal})">
          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          Preview
        </button>
        <button type="button" class="env-file-preview-btn env-import-row-btn"
          id="ef-import-${prefix}-${esc(f)}"
          onclick="importEnvVarsInline(this,'${cwdEnc}','${esc(f)}',${isModal})">
          <svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add to env
        </button>
        ${removeBtn}
      </div>
      <div class="env-file-preview" id="ef-preview-${prefix}-${esc(f)}">
        <span style="color:var(--gray-300);font-style:italic">Loading…</span>
      </div>
    </div>`;
  }).join('');
}

function _envFileScanCache(isModal) {
  return isModal ? (_addEnvFilesScan || []) : (_envFilesScan || []);
}
let _envFilesScan = [];
let _addEnvFilesScan = [];

async function scanEnvFiles(cwd, isModal) {
  if (!cwd) return;
  const listId = isModal ? 'f-env-file-list' : 'p-env-file-list';
  const container = document.getElementById(listId);
  if (!container) return;
  if (isModal) _envFileCwdModal = cwd; else _envFileCwd = cwd;
  try {
    const res = await api('GET', `/api/scan-env-files?path=${encodeURIComponent(cwd)}`);
    const files = res.files || [];
    if (isModal) _addEnvFilesScan = files; else _envFilesScan = files;
    if (!files.length) {
      container.innerHTML = '<span class="env-file-empty">Không tìm thấy file .env nào trong thư mục</span>';
      return;
    }
    container.innerHTML = _buildEnvFileRows(files, cwd, isModal);
  } catch {}
}

async function toggleEnvPreview(btn, cwdEnc, file, isModal) {
  const prefix = isModal ? 'f' : 'p';
  const preview = document.getElementById(`ef-preview-${prefix}-${file}`);
  if (!preview) return;
  if (preview.classList.toggle('open')) {
    btn.querySelector('svg').style.transform = 'rotate(180deg)';
    if (preview.dataset.loaded) return;
    preview.dataset.loaded = '1';
    try {
      const res = await api('GET', `/api/parse-env-file?path=${cwdEnc}&file=${encodeURIComponent(file)}`);
      const vars = res.vars || {};
      const keys = Object.keys(vars);
      if (!keys.length) {
        preview.innerHTML = '<span style="color:var(--gray-300);font-style:italic;padding:6px 0;display:block">File trống hoặc không có biến</span>';
        return;
      }
      // Store vars on element for import
      preview.dataset.vars = JSON.stringify(vars);
      preview.innerHTML = keys.map(k =>
        `<div class="env-file-preview-line">
          <span class="env-file-preview-key">${esc(k)}</span>
          <span class="env-file-preview-val">= ${esc(String(vars[k]).substring(0, 60))}${String(vars[k]).length > 60 ? '…' : ''}</span>
        </div>`).join('');
    } catch { preview.innerHTML = '<span style="color:var(--red)">Không đọc được file</span>'; }
  } else {
    btn.querySelector('svg').style.transform = '';
  }
}

async function importEnvVarsInline(btn, cwdEnc, file, isModal) {
  btn.disabled = true;
  btn.textContent = '…';
  try {
    const res = await api('GET', `/api/parse-env-file?path=${cwdEnc}&file=${encodeURIComponent(file)}`);
    const vars = res.vars || {};
    const keys = Object.keys(vars);
    if (!keys.length) { btn.textContent = 'Empty'; return; }
    keys.forEach(k => addEnvVarRow(k, String(vars[k]), isModal));
    btn.innerHTML = `<svg width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> ${keys.length} added`;
    btn.style.color = 'var(--green)';
    btn.style.borderColor = '#bbf7d0';
  } catch {
    btn.textContent = 'Error'; btn.disabled = false;
  }
}

function removeEnvFileRow(file, isModal) {
  const prefix = isModal ? 'f' : 'p';
  const row = document.getElementById(`ef-row-${prefix}-${file}`);
  if (row) row.remove();
  if (isModal) _addEnvFilesScan = _addEnvFilesScan.filter(f => f !== file);
  else _envFilesScan = _envFilesScan.filter(f => f !== file);
}

function renderAddEnvFileTags(files) {
  const cwd = _envFileCwdModal;
  const container = document.getElementById('f-env-file-list');
  if (!container) return;
  const all = [...new Set([..._addEnvFilesScan, ...files.filter(Boolean)])];
  if (!all.length) { container.innerHTML = '<span class="env-file-empty">Không tìm thấy file .env nào</span>'; return; }
  container.innerHTML = _buildEnvFileRows(all, cwd, true);
}
function getAddEnvFiles() { return [..._addEnvFilesScan]; }

// ── Env variable key-value editor ──
function renderEnvVars(vars, isModal) {
  const listId = isModal ? 'f-env-vars-list' : 'p-env-vars-list';
  const container = document.getElementById(listId);
  if (!container) return;
  container.innerHTML = '';
  Object.entries(vars).forEach(([k, v]) => _appendEnvVarRow(container, k, v));
}
function addEnvVarRow(key, val, isModal) {
  const listId = isModal ? 'f-env-vars-list' : 'p-env-vars-list';
  const container = document.getElementById(listId);
  if (!container) return;
  // Check duplicate key
  const existing = container.querySelectorAll('.kv-key');
  for (const inp of existing) { if (inp.value.trim() === key && key) return; }
  _appendEnvVarRow(container, key, val);
}
function _appendEnvVarRow(container, key, val) {
  const row = document.createElement('div');
  row.className = 'env-var-row';
  row.innerHTML = `
    <input class="kv-input kv-key" placeholder="KEY" value="${esc(key)}">
    <input class="kv-input kv-val" placeholder="value" value="${esc(String(val||''))}">
    <button type="button" class="kv-del" onclick="this.closest('.env-var-row').remove()" title="Remove">×</button>`;
  container.appendChild(row);
  // Focus key if empty
  if (!key) row.querySelector('.kv-key').focus();
}
function getEnvVars(isModal) {
  const listId = isModal ? 'f-env-vars-list' : 'p-env-vars-list';
  const container = document.getElementById(listId);
  if (!container) return {};
  const vars = {};
  container.querySelectorAll('.env-var-row').forEach(row => {
    const k = row.querySelector('.kv-key').value.trim();
    const v = row.querySelector('.kv-val').value;
    if (k) vars[k] = v;
  });
  return vars;
}

// ─── Ecosystem File Upload ───
function handleEcoFileSelect(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    pendingEcoFileContent = e.target.result;
    document.getElementById('uploadZoneText').textContent = `✓ ${file.name} loaded — click Upload & Sync to apply`;
    document.getElementById('uploadZone').classList.add('has-file');
    document.getElementById('ecoUploadBtn').style.display = '';
  };
  reader.readAsText(file);
}

async function uploadProjectEcosystem() {
  if (!pendingEcoFileContent) return toast('No file loaded.', 'warn');
  const r = await api('POST', `/api/projects/${encodeURIComponent(currentSelectedProject)}/ecosystem`, { content: pendingEcoFileContent });
  if (r.success) {
    toast(r.merged ? 'Ecosystem file uploaded and settings merged!' : 'File saved (manual merge may be needed).', 'ok');
    pendingEcoFileContent = null;
    document.getElementById('ecoUploadBtn').style.display = 'none';
    document.getElementById('uploadZone').classList.remove('has-file');
    document.getElementById('uploadZoneText').textContent = 'Click to upload ecosystem.config.js — config will be merged automatically';
    loadProjects();
  } else {
    toast(r.error || 'Upload failed.', 'err');
  }
}

async function viewProjectEcosystem() {
  const r = await api('GET', `/api/projects/${encodeURIComponent(currentSelectedProject)}/ecosystem`);
  document.getElementById('ecoViewTitle').textContent = `ecosystem.config.js — ${currentSelectedProject}`;
  document.getElementById('ecoViewContent').value = r.content || '// No ecosystem file found for this project.';
  document.getElementById('ecoViewModal').classList.add('open');
}

