<div class="toast" id="toast"></div>

<script>
// ─── Auth ───
const TOKEN_KEY = 'da_token';
function getToken() { return localStorage.getItem(TOKEN_KEY) || ''; }
function authHeaders() { return { 'Content-Type': 'application/json', 'Authorization': getToken() }; }
function logout() { localStorage.removeItem(TOKEN_KEY); window.location.href = '/'; }

async function api(method, path, body) {
  const r = await fetch(path, { method, headers: authHeaders(), body: body ? JSON.stringify(body) : undefined });
  if (r.status === 401) { logout(); throw new Error('Unauthorized'); }
  return r.json();
}

// ─── Toast ───
let toastTimer;
function toast(msg, type = 'ok') {
  const el = document.getElementById('toast');
  const icon = type === 'ok' ? '<i class="bi bi-check-circle-fill"></i>' : 
               type === 'err' ? '<i class="bi bi-x-circle-fill"></i>' :
               type === 'warn' ? '<i class="bi bi-exclamation-triangle-fill"></i>' :
               '<i class="bi bi-info-circle-fill"></i>';
  el.innerHTML = `${icon} <span>${msg}</span>`;
  el.className = `toast show toast-${type}`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3500);
}

// ─── Confirm Modal ───
let confirmCb = null;
function showConfirm(title, message, cb, isDanger = false) {
  document.getElementById('confirmTitle').textContent = title;
  document.getElementById('confirmMessage').textContent = message;
  const btn = document.getElementById('confirmActionBtn');
  btn.className = `btn ${isDanger ? 'btn-danger' : 'btn-primary'}`;
  btn.textContent = isDanger ? 'Delete' : 'Confirm';
  confirmCb = cb;
  document.getElementById('confirmModal').classList.add('open');
}
function executeConfirm() { if (confirmCb) confirmCb(); closeConfirm(); }
function closeConfirm() { document.getElementById('confirmModal').classList.remove('open'); confirmCb = null; }

// ─── Modals ───
function openAddModal() {
  // Reset to step 1 state
  document.getElementById('addDetailStep').classList.remove('visible');
  document.getElementById('addModalFooter').classList.remove('visible');
  document.getElementById('f-cwd').value = '';
  document.getElementById('f-dir-status').innerHTML = 'Chọn thư mục để tự động phát hiện framework &amp; file env.';
  document.getElementById('f-dir-status').style.color = 'var(--gray-400)';
  document.getElementById('addModal').classList.add('open');
}
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function revealAddDetails() {
  document.getElementById('addDetailStep').classList.add('visible');
  document.getElementById('addModalFooter').classList.add('visible');
}

async function onCwdChange(val) {
  val = val.trim();
  if (!val) return;
  const status = document.getElementById('f-dir-status');
  status.style.color = 'var(--gray-400)';
  status.textContent = 'Đang phân tích…';
  revealAddDetails();
  // Auto-set project name from folder name if empty
  const folderName = val.split('/').filter(Boolean).pop() || '';
  if (!document.getElementById('f-name').value && folderName) {
    document.getElementById('f-name').value = folderName;
  }
  await Promise.all([
    autoDetectConfig(val),
    scanEnvFiles(val, true),
  ]);
  status.style.color = 'var(--green)';
  status.innerHTML = `<svg width="12" height="12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg> ${esc(val)}`;
}

// ─── State ───
let projects = [];
let ws, browserCurrentPath;
let currentSelectedProject = null;
let rawTokens = {};
let pendingEcoFileContent = null;

let chartData = {};
let perfChartObj = null;

function updateChartLive(p) {
  if (!chartData[p.name]) chartData[p.name] = { cpu: Array(20).fill(0), mem: Array(20).fill(0) };
  let h = chartData[p.name];
  h.cpu.push(p.cpu || 0); h.cpu.shift();
  h.mem.push((p.memory||0)/(1024*1024)); h.mem.shift();

  if (document.getElementById('pview-dashboard').classList.contains('hidden')) return;

  const ctx = document.getElementById('perfChart');
  if (!ctx) return;
  if (!perfChartObj) {
    perfChartObj = new Chart(ctx, {
      type: 'line',
      data: {
        labels: Array(20).fill(''),
        datasets: [
          { label: 'CPU %', data: h.cpu, borderColor: '#a855f7', backgroundColor: 'rgba(168,85,247,0.1)', fill: true, tension: 0.4 },
          { label: 'Memory (MB)', data: h.mem, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.1)', fill: true, tension: 0.4, yAxisID: 'y1' }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        animation: { duration: 0 },
        scales: {
          y: { min: 0, suggestedMax: 100 },
          y1: { position: 'right', min: 0 }
        },
        plugins: { legend: { display: false } }
      }
    });
  } else {
    perfChartObj.data.datasets[0].data = h.cpu;
    perfChartObj.data.datasets[1].data = h.mem;
    perfChartObj.update();
  }
}
let execMode = 'fork';

// ─── Init ───
async function init() {
  const me = await api('GET', '/api/me');
  if (me.error) { logout(); return; }
  
  if (me.logoUrl) {
    const logoEl = document.querySelector('.topbar-logo');
    logoEl.innerHTML = `<img src="${me.logoUrl}" style="width:100%;height:100%;object-fit:cover;border-radius:6px;" />`;
    logoEl.style.background = 'transparent';
  }
  
  const navStr = `@${me.orgName}/${me.cliName}`;
  document.getElementById('navPkg').textContent = navStr;
  const menuPkg = document.getElementById('navPkgMenu');
  if (menuPkg) menuPkg.textContent = navStr;
  const topTitle = document.getElementById('topbarTitle');
  if (topTitle) topTitle.textContent = me.cliName.toUpperCase();
  
  document.getElementById('s-username').textContent = me.username;
  document.getElementById('s-org').textContent = me.orgName;
  document.getElementById('s-cli').textContent = me.cliName;
  document.getElementById('s-created').textContent = me.createdAt ? new Date(me.createdAt).toLocaleDateString() : '—';
  document.getElementById('tokenDisplay').textContent = getToken();
  loadProjects();
  checkPm2();
  loadSysInfo();
  loadPm2Config();
  initWS();
}

// ─── WebSocket ───
function initWS() {
  ws = new WebSocket(`ws://${location.host}?token=${encodeURIComponent(getToken())}`);
  ws.onopen = () => appendTerm('\x1b[32mShell connected.\x1b[0m\r\n');
  ws.onmessage = e => {
    const msg = JSON.parse(e.data);
    if (msg.type === 'terminal') appendTerm(msg.data);
    else if (msg.type === 'log') appendGlobalLog(msg.data);
    else if (msg.type === 'project_log' && msg.project === currentSelectedProject) appendProjectLog(msg.data);
    else if (msg.type === 'term_out' && currentSelectedProject === msg.project) appendTerm(msg.data);
    else if (msg.type === 'refresh') {
      // Only refresh sidebar list + metrics — never touch form/settings content
      loadProjects();
    }
    else if (msg.type === 'reset') { localStorage.removeItem(TOKEN_KEY); window.location.href = '/setup'; }
  };
  ws.onclose = () => appendTerm('\r\n\x1b[31m[Shell disconnected]\x1b[0m\r\n');
}

// ─── ANSI ───
function ansiToHtml(raw) {
  const C = {'30':'#6b7280','31':'#ef4444','32':'#22c55e','33':'#eab308','34':'#3b82f6','35':'#a855f7','36':'#06b6d4','37':'#f3f4f6','90':'#9ca3af','91':'#f87171','92':'#4ade80','93':'#facc15','94':'#60a5fa','95':'#c084fc','96':'#22d3ee','97':'#ffffff'};
  let out='', cur=null;
  const parts = raw.split(/\x1b\[([0-9;]*)m/);
  for (let i=0;i<parts.length;i++) {
    if (i%2===0) {
      const safe = parts[i].replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      out += cur ? `<span style="color:${cur}">${safe}</span>` : safe;
    } else {
      if (parts[i]==='0'||parts[i]==='') cur=null;
      else { for (const c of parts[i].split(';')) if (C[c]) { cur=C[c]; break; } }
    }
  }
  return out;
}

function appendTerm(raw) {
  const el = document.getElementById('termOutput');
  const s = document.createElement('span');
  s.innerHTML = ansiToHtml(raw.replace(/\r\n/g,'\n').replace(/\r/g,'\n'));
  el.appendChild(s); el.scrollTop = el.scrollHeight;
}
function clearTerm() { document.getElementById('termOutput').innerHTML = ''; }
function handleKey(e) {
  if (e.key === 'Enter') {
    const v = e.target.value; if (!v.trim()) return;
    if (ws?.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type:'terminal_input', data: v+'\n' }));
    appendTerm(`\x1b[90m$ ${v}\x1b[0m\n`);
    e.target.value = '';
  }
}
function appendGlobalLog(text) {
  const el = document.getElementById('globalLogStream');
  if (el) { el.textContent += text; el.scrollTop = el.scrollHeight; }
}
function clearGlobalLog() { 
  const el = document.getElementById('globalLogStream');
  if (el) el.textContent = ''; 
}
function appendProjectLog(raw) {
  const el = document.getElementById('pv-logStream');
  const s = document.createElement('span');
  s.innerHTML = ansiToHtml(raw.replace(/\r\n/g,'\n').replace(/\r/g,'\n'));
  el.appendChild(s); el.scrollTop = el.scrollHeight;
}
function clearProjectLogs() { document.getElementById('pv-logStream').innerHTML = ''; }

// ─── Navigation ───
function setSideTab(tab) {
  ['projects','logs'].forEach(t => {
    document.getElementById(`spanel-${t}`).classList.toggle('active', t===tab);
    document.getElementById(`stab-${t}`).classList.toggle('active', t===tab);
  });
}

function setMainTab(tab) {
  ['overview','settings','cloud','project'].forEach(t => {
    const p = document.getElementById(`mpanel-${t}`);
    const m = document.getElementById(`mtab-${t}`);
    if (p) p.classList.toggle('active', t===tab);
    if (m) m.classList.toggle('active', t===tab);
  });
  if (tab === 'overview') renderOverview();
  if (tab === 'settings') loadPm2Config();
  if (tab === 'cloud') loadCloudFiles();
  if (tab === 'project' && currentSelectedProject) renderProjectView();
}

// ─── Projects ───
async function loadProjects() {
  projects = await api('GET', '/api/projects');
  renderProjectList();
  renderOverview();
  if (currentSelectedProject) {
    const still = projects.find(p => p.name === currentSelectedProject);
    if (!still) {
      currentSelectedProject = null;
      document.getElementById('mtab-project').classList.add('hidden');
      setMainTab('overview');
    } else {
      // Only update metrics (status/CPU/memory) — do NOT reset form/env state
      _renderProjectMetrics(still);
    }
  }
}

function statusDotClass(s) {
  return { online: 'dot-online', stopped: 'dot-stopped', errored: 'dot-errored', launching: 'dot-launching' }[s] || 'dot-stopped';
}
function typeClass(t) {
  return `type-${t||'Other'}`;
}
function memFmt(b) { return b > 0 ? (b/1024/1024).toFixed(1)+' MB' : '—'; }
function timeFmt(ms) { if(!ms) return '0s'; let s=Math.floor((Date.now()-ms)/1000); let m=Math.floor(s/60); s%=60; let h=Math.floor(m/60); m%=60; let d=Math.floor(h/24); h%=24; if(d>0)return`${d}d ${h}h`; if(h>0)return`${h}h ${m}m`; if(m>0)return`${m}m ${s}s`; return`${s}s`; }

function renderProjectList() {
  const list = document.getElementById('projectList');
  const empty = document.getElementById('projectEmpty');
  if (!projects.length) { list.innerHTML = ''; empty.classList.remove('hidden'); return; }
  empty.classList.add('hidden');
  list.innerHTML = projects.map(p => `
    <div class="proj-item${p.name===currentSelectedProject?' selected':''}" onclick="selectProject('${esc(p.name)}')">
      <div class="proj-row">
        <div class="dot-status ${statusDotClass(p.status)}"></div>
        <span class="proj-name">${esc(p.name)}</span>
        <span class="proj-type ${typeClass(p.type)}">${p.type||'Other'}</span>
      </div>
      <div class="proj-meta">
        <span style="color:${p.status==='online'?'#22c55e':(p.status==='errored'?'#ef4444':'var(--gray-400)')}">${p.status||'stopped'}</span>
        ${p.memory > 0 ? `<span>· ${memFmt(p.memory)}</span>` : ''}
        ${p.cpu > 0 ? `<span>· ${p.cpu}%</span>` : ''}
      </div>
      <div class="proj-actions">
        <button class="pa-btn start" onclick="event.stopPropagation();runAction('start','${esc(p.name)}')">▶</button>
        <button class="pa-btn restart" onclick="event.stopPropagation();runAction('restart','${esc(p.name)}')">↺</button>
        <button class="pa-btn stop" onclick="event.stopPropagation();runAction('stop','${esc(p.name)}')">■</button>
        <button class="pa-btn del" onclick="event.stopPropagation();deleteProject('${esc(p.name)}')">✕</button>
      </div>
    </div>`).join('');
}

function renderOverview() {
  const el = document.getElementById('overviewGrid');
  if (!projects.length) {
    el.innerHTML = '<div class="empty-state" style="grid-column:1/-1"><svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg><span>No projects yet. Add one to get started.</span></div>';
    return;
  }
  el.innerHTML = projects.map(p => `
    <div class="ov-card" onclick="selectProject('${esc(p.name)}')" style="cursor:pointer">
      <div class="ov-card-head">
        <div class="dot-status ${statusDotClass(p.status)}"></div>
        <span class="ov-name">${esc(p.name)}</span>
        <span class="proj-type ${typeClass(p.type)}">${p.type||'Other'}</span>
        <span class="ov-status" style="color:${p.status==='online'?'#22c55e':(p.status==='errored'?'#ef4444':'var(--gray-400)')}">${p.status||'stopped'}</span>
      </div>
      <div class="ov-path" title="${esc(p.cwd)}">${esc(p.cwd)}</div>
      <div class="ov-stats">
        <div class="ov-stat"><div class="ov-stat-label">Memory</div><div class="ov-stat-val">${memFmt(p.memory)}</div></div>
        <div class="ov-stat"><div class="ov-stat-label">CPU</div><div class="ov-stat-val">${p.cpu||0}%</div></div>
        <div class="ov-stat"><div class="ov-stat-label">PID</div><div class="ov-stat-val">${p.pid||'—'}</div></div>
      </div>
      <div class="ov-actions">
        <button class="ov-btn" onclick="event.stopPropagation();runAction('start','${esc(p.name)}')">▶ Start</button>
        <button class="ov-btn" onclick="event.stopPropagation();runAction('restart','${esc(p.name)}')">↺ Restart</button>
        <button class="ov-btn" onclick="event.stopPropagation();runAction('stop','${esc(p.name)}')">■ Stop</button>
      </div>
    </div>`).join('');
}

// ─── Project selection ───
function selectProject(name) {
  const p = projects.find(x => x.name === name);
  if (!p) return;
  currentSelectedProject = name;
  document.getElementById('mtab-project').classList.remove('hidden');
  document.getElementById('mtab-project-label').textContent = name;
  renderProjectList();
  setMainTab('project'); // calls renderProjectView() internally
  setProjectSubTab('dashboard');
}

// Full render — called only when explicitly selecting a project
function renderProjectView() {
  const p = projects.find(x => x.name === currentSelectedProject);
  if (!p) return;
  _renderProjectMetrics(p);
  // Fill settings form (only on full render, never on WS refresh)
  document.getElementById('p-cwd').value = p.cwd || '';
  document.getElementById('p-script').value = p.script || 'npm';
  document.getElementById('p-args').value = p.args || 'run dev';
  document.getElementById('p-autorestart').checked = p.autorestart !== false;
  document.getElementById('p-watch').checked = p.watch === true;
  // Max memory — parse e.g. "512M" or "2G"
  const mem = p.max_memory_restart || '';
  const memMatch = mem.match(/^(\d+)(M|G)$/i);
  const memOn = !!memMatch;
  document.getElementById('p-max-memory-on').checked = memOn;
  document.getElementById('p-max-memory-val').value = memMatch ? memMatch[1] : '512';
  document.getElementById('p-max-memory-unit').value = memMatch ? memMatch[2].toUpperCase() : 'M';
  document.getElementById('limit-control-max-memory').classList.toggle('active', memOn);
  // Kill timeout
  const ktOn = !!p.kill_timeout;
  document.getElementById('p-kill-timeout-on').checked = ktOn;
  document.getElementById('p-kill-timeout-val').value = p.kill_timeout || 3000;
  document.getElementById('limit-control-kill-timeout').classList.toggle('active', ktOn);
  // Restart delay
  const rdOn = !!p.restart_delay;
  document.getElementById('p-restart-delay-on').checked = rdOn;
  document.getElementById('p-restart-delay-val').value = p.restart_delay || 0;
  document.getElementById('limit-control-restart-delay').classList.toggle('active', rdOn);
  document.getElementById('p-instances').value = p.instances || 1;
  setExecMode(p.exec_mode || 'fork');
  renderEnvVars(p.env || {}, false);
  scanEnvFiles(p.cwd, false);
  // Reset upload zone
  pendingEcoFileContent = null;
  document.getElementById('uploadZoneText').textContent = 'Click to upload ecosystem.config.js — config will be merged automatically';
  document.getElementById('uploadZone').classList.remove('has-file');
  document.getElementById('ecoUploadBtn').style.display = 'none';
  document.getElementById('ecoViewBtn').style.display = '';
}

// Lightweight refresh — only updates metrics/status, never touches form state
function _renderProjectMetrics(p) {
  document.getElementById('pv-name').textContent = p.name;
  const statusColor = p.status==='online' ? '#22c55e' : (p.status==='errored' ? '#ef4444' : '#94a3b8');
  const statusIcon = p.status==='online' ? '<i class="bi bi-activity"></i>' : (p.status==='errored' ? '<i class="bi bi-x-circle"></i>' : '<i class="bi bi-pause-circle"></i>');
  const statusBg = p.status==='online' ? '#f0fdf4' : (p.status==='errored' ? '#fef2f2' : '#f1f5f9');
  
  const st = document.getElementById('pv-status-text');
  st.textContent = p.status || 'stopped';
  st.style.color = statusColor;
  document.getElementById('pv-dot').className = `dot-status ${statusDotClass(p.status)}`;
  
  const maxMemAdd = p.max_memory_restart ? `<div class="metric-card"><div class="metric-icon" style="background:#f3f4f6;color:#6b7280"><i class="bi bi-shield-fill-exclamation"></i></div><div><div class="metric-label">Max Memory Limit</div><div class="metric-val">${p.max_memory_restart}</div></div></div>` : '';

  document.getElementById('pv-metrics').innerHTML = `
    <div class="metric-card">
      <div class="metric-icon" style="background:${statusBg};color:${statusColor}">${statusIcon}</div>
      <div>
        <div class="metric-label">Service Status</div>
        <div class="metric-val" style="font-size:24px;color:${statusColor};text-transform:capitalize">${p.status||'stopped'}</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon" style="background:#eff6ff;color:#3b82f6"><i class="bi bi-clock-history"></i></div>
      <div>
        <div class="metric-label">Uptime</div>
        <div class="metric-val" style="font-size:24px">${p.uptime ? timeFmt(p.uptime) : '—'}</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon" style="background:#fef2f2;color:#ef4444"><i class="bi bi-arrow-repeat"></i></div>
      <div>
        <div class="metric-label">Restarts</div>
        <div class="metric-val">${p.restarts||0}</div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon" style="background:#fffbeb;color:#f59e0b"><i class="bi bi-memory"></i></div>
      <div>
        <div class="metric-label">Memory</div>
        <div class="metric-val">${memFmt(p.memory).replace(' MB','')}<span>MB</span></div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon" style="background:#faf5ff;color:#a855f7"><i class="bi bi-cpu"></i></div>
      <div>
        <div class="metric-label">CPU Usage</div>
        <div class="metric-val">${p.cpu||0}<span>%</span></div>
      </div>
    </div>
    <div class="metric-card">
      <div class="metric-icon" style="background:#f8fafc;color:#1e293b"><i class="bi bi-gear-wide-connected"></i></div>
      <div>
        <div class="metric-label">Exec Mode</div>
        <div class="metric-val" style="font-size:20px">${p.exec_mode||'fork'}</div>
        <div style="font-size:12px;font-weight:600;color:var(--gray-500);margin-top:2px">${p.instances ? `${p.instances} workers processing` : 'Single node'}</div>
      </div>
    </div>
    <div class="metric-card" style="grid-column:1/-1; flex-direction:row; justify-content:space-between; align-items:center;">
      <div style="display:flex; align-items:center; gap:16px;">
        <div class="metric-icon" style="background:#f1f5f9;color:#64748b;margin:0;width:54px;height:54px;font-size:26px"><i class="bi bi-folder2-open"></i></div>
        <div>
          <div class="metric-label" style="margin-bottom:6px">Working Directory</div>
          <div style="font-size:15px; font-weight:600; color:var(--gray-700); font-family: 'JetBrains Mono', monospace;">${esc(p.cwd)}</div>
        </div>
      </div>
      <div style="text-align:right">
        <div class="metric-label" style="margin-bottom:6px">Framework</div>
        <div style="font-size:18px; font-weight:700; color:var(--black)">${p.framework||'Other'}</div>
      </div>
