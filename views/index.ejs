function setProjectSubTab(tab) {
  ['dashboard','logs','terminal','config'].forEach(t => {
    const el = document.getElementById(`pview-${t}`);
    const btn = document.getElementById(`ptab-${t}`);
    if (el) el.classList.toggle('hidden', t !== tab);
    if (btn) btn.classList.toggle('active', t === tab);
  });
  if (tab === 'logs') {
    clearProjectLogs();
    if (ws?.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type: 'subscribe_project_logs', project: currentSelectedProject }));
  } else {
    if (ws?.readyState === WebSocket.OPEN) ws.send(JSON.stringify({ type: 'unsubscribe_project_logs' }));
  }
}

// ─── Exec Mode Toggle ───
function toggleLimitField(key) {
  const on = document.getElementById(`p-${key}-on`).checked;
  document.getElementById(`limit-control-${key}`).classList.toggle('active', on);
}

function setExecMode(mode) {
  execMode = mode;
  document.getElementById('p-exec-mode').value = mode;
  document.getElementById('em-fork').classList.toggle('selected', mode === 'fork');
  document.getElementById('em-cluster').classList.toggle('selected', mode === 'cluster');
